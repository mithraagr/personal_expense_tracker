APP_NAME=Personal Expense Management
APP_ENV=development
DEBUG=true
API_PREFIX=/api
SECRET_KEY=change_this_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./expenses.db
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_CITY=Default
DEFAULT_ADMIN_PASSWORD=Admin@123
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_USE_TLS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+):[0-9]+$
